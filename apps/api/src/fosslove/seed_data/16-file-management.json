      "linux": [
        {
          "manager": "flatpak",
          "identifier": "org.kde.filelight"
        },
        {
          "manager": "apt",
          "identifier": "filelight"
        },
        {
          "manager": "dnf",
          "identifier": "filelight"
        },
        {
          "manager": "pacman",
          "identifier": "filelight"
        }
      ]
    }

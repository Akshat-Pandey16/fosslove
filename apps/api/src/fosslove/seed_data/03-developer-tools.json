      "windows": [
        {
          "manager": "winget",
          "identifier": "Git.Git"
        }
      ],
      "linux": [
        {
          "manager": "apt",
          "identifier": "git"
        },
        {
          "manager": "dnf",
          "identifier": "git"
        },
        {
          "manager": "pacman",
          "identifier": "git"
        }
      ]
    },
    {

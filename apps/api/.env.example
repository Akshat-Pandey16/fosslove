FOSSLOVE_ENV=local
FOSSLOVE_DEBUG=true
FOSSLOVE_LOG_LEVEL=INFO
FOSSLOVE_LOG_JSON=false

FOSSLOVE_SECRET_KEY=change-me-to-a-long-random-secret-value-please
FOSSLOVE_ACCESS_TOKEN_TTL_SECONDS=900
FOSSLOVE_REFRESH_TOKEN_TTL_SECONDS=1209600
FOSSLOVE_EMAIL_TOKEN_TTL_SECONDS=86400

FOSSLOVE_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
FOSSLOVE_ALLOWED_HOSTS=*
FOSSLOVE_TRUSTED_PROXY_COUNT=0

FOSSLOVE_POSTGRES_HOST=localhost
FOSSLOVE_POSTGRES_PORT=5544
FOSSLOVE_POSTGRES_USER=fosslove
FOSSLOVE_POSTGRES_PASSWORD=fosslove
FOSSLOVE_POSTGRES_DB=fosslove
FOSSLOVE_DB_POOL_SIZE=10
FOSSLOVE_DB_MAX_OVERFLOW=20
FOSSLOVE_DB_POOL_TIMEOUT=30
FOSSLOVE_DB_POOL_RECYCLE=1800
FOSSLOVE_DB_CONNECT_TIMEOUT=10
FOSSLOVE_DB_STATEMENT_TIMEOUT_MS=30000
FOSSLOVE_DB_ECHO=false

FOSSLOVE_REDIS_URL=redis://localhost:6390/0

FOSSLOVE_RATE_LIMIT_ENABLED=true
FOSSLOVE_RATE_LIMIT_DEFAULT=200/minute
FOSSLOVE_RATE_LIMIT_AUTH=10/minute

FOSSLOVE_REGISTRATION_ENABLED=true

FOSSLOVE_EMAIL_ENABLED=false
FOSSLOVE_EMAIL_BACKEND=smtp
FOSSLOVE_EMAIL_FROM=no-reply@fosslove.dev
FOSSLOVE_SMTP_HOST=smtp.gmail.com
FOSSLOVE_SMTP_PORT=587
FOSSLOVE_SMTP_USER=
FOSSLOVE_SMTP_PASSWORD=
FOSSLOVE_SMTP_USE_TLS=true

FOSSLOVE_FRONTEND_BASE_URL=http://localhost:3000

FOSSLOVE_FIRST_ADMIN_EMAIL=admin@fosslove.dev
FOSSLOVE_FIRST_ADMIN_PASSWORD=
